{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "pr_log record",
  "description": "One JSON object per line in pr_log.jsonl. DERIVED from GitHub (gh) — regenerable, never hand-edited.",
  "type": "object",
  "required": ["pr", "repo", "title", "head_sha", "state"],
  "additionalProperties": true,
  "properties": {
    "pr": { "type": "integer", "description": "PR number" },
    "repo": { "type": "string", "description": "owner/name" },
    "title": { "type": "string" },
    "task_id": { "type": ["string", "null"], "description": "linked task-card / ST / requirement id, parsed from PR body (e.g. ST-P8-11)" },
    "head_sha": { "type": "string" },
    "base": { "type": "string" },
    "state": { "type": "string", "enum": ["open", "closed", "merged"] },
    "author": { "type": ["string", "null"] },
    "created_at": { "type": "string" },
    "merged_at": { "type": ["string", "null"] },
    "files_changed": { "type": ["integer", "null"] },
    "additions": { "type": ["integer", "null"] },
    "deletions": { "type": ["integer", "null"] },
    "ci": {
      "type": "object",
      "description": "non-AI gate results keyed by check name",
      "additionalProperties": { "type": "string" }
    },
    "review": {
      "type": "object",
      "properties": {
        "kind": { "type": "string", "enum": ["code", "proposal"], "description": "review kind: code = code-diff review (default for legacy records without this field), proposal = design/decision/ADR reasoning review" },
        "verdict": { "type": "string", "enum": ["approve", "approve_after_fixes", "request_changes", "needs_human"] },
        "summary": { "type": "string" },
        "rounds": { "type": "integer", "description": "how many review iterations" },
        "backend": { "type": "string", "enum": ["api", "claude-cli"] },
        "overlay": { "type": "boolean" },
        "mode": { "type": "string", "enum": ["deep", "gate", "confirm-fixes"] },
        "profile": { "type": "string", "enum": ["standard", "pilot_minimal"] },
        "findings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["severity", "area", "issue"],
            "properties": {
              "severity": { "type": "string", "enum": ["high", "med", "low"] },
              "area": { "type": "string", "enum": ["A_authz", "B_contract", "C_policy", "D_visual", "E_reliability", "other", "R1_argument", "R2_rootcause_fix", "R3_disconfirm", "R4_alternatives", "R5_metric_gaming", "R6_domain", "R7_scope", "R8_honesty"], "description": "code-review areas (A_*..E_*/other) or proposal-review reasoning lenses (R1_*..R8_*)" },
              "location": { "type": "string" },
              "issue": { "type": "string" },
              "turned_into_test": { "type": ["string", "null"], "description": "path::testname of the regression test, or null if not yet" },
              "status": { "type": "string", "enum": ["open", "fixed", "wontfix", "deferred"] }
            }
          }
        }
      }
    }
  }
}
